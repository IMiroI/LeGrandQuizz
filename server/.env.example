# Port du serveur backend (doit correspondre à proxy.conf.json → :3004)
PORT=3004

# MongoDB URI
MONGO_URI=mongodb://127.0.0.1:27017/LEGRANDQUIZZ

# Clé secrète partagée avec VGAMES (doit être identique à SECRET_KEY dans VGAMES/.env)
SECRET_KEY=your_secret_key_here

# URL du frontend Angular (utilisée pour restreindre CORS et Socket.io)
FRONTEND_URL=http://localhost:3001
