# Clé secrète partagée avec VGAMES (doit être identique à SECRET_KEY dans VGAMES/.env)
SECRET_KEY=your_secret_key_here

PORT=3001
APP_URL=http://localhost:3001
VGAMES_URL=http://localhost:3000

# MongoDB — même serveur que VGAMES en prod, base LEGRANDQUIZZ dédiée
MONGO_URI=mongodb://127.0.0.1:27017/LEGRANDQUIZZ
